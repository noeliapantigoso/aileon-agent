# Copy this file to .env and fill in your own values
# DO NOT commit .env to git

# === API Keys ===
GEMINI_API_KEY=AIza...                     # AI Studio key, or leave empty if using Vertex AI
NOTION_TOKEN=ntn_...                       # Notion internal integration token

# === Telegram Bot ===
TELEGRAM_BOT_TOKEN=000000000:AAA...        # From @BotFather
TELEGRAM_ALLOWED_USER_ID=123456789         # Your Telegram user id (from @userinfobot)
TELEGRAM_WEBHOOK_SECRET=                   # Random URL-safe token, generate with secrets.token_urlsafe(32)
TELEGRAM_WEBHOOK_URL=                      # Cloud Run public URL after deploy

# === GCP ===
GCP_PROJECT_ID=your-gcp-project            # Required for Vertex AI + Firestore
GCS_BUCKET_NAME=                           # Optional, for audio uploads
FIRESTORE_COLLECTION_PREFIX=assistant

# === Notion Database IDs ===
# Get from the Notion DB URL: notion.so/xxxxx?v=yyy → xxxxx
NOTION_TASKS_DB=
NOTION_NOTES_DB=
NOTION_GOALS_DB=
NOTION_DAILY_AGENDA_DB=

# === Firebase Auth (optional, for PWA) ===
ALLOWED_EMAIL=
FIREBASE_CREDENTIALS_PATH=

# === Mem0 (optional, episodic memory) ===
MEM0_API_KEY=

# === User ===
USER_NAME=YourName
USER_TIMEZONE=America/Lima
USER_ID=user

# === Proactive Messages ===
PROACTIVE_SECRET=                          # Random URL-safe token for /proactive endpoint auth

# === Server ===
DEBUG=false
LOG_LEVEL=INFO
